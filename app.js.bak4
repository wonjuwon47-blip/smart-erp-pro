    saveDb();
    renderEmployeeList();
    formEmpAdd.reset();
  });
}

window.deleteEmployee = function(idx) {
  if(confirm("해당 사원 정보를 영구 삭제하시겠습니까?")) {
    db.employees.splice(idx, 1);
    saveDb();
    renderEmployeeList();
  }
};

// 은행 관리 (은행정보.png 관련)
const formBankAdd = document.getElementById("form-bank-add");
